    "version": "0.2.0",
    "configurations": [
        {
            "command": "npm run test:filter",
            "name": "Run npm test:filter (terminal only)",
            "request": "launch",
            "type": "node-terminal",
            "noDebug": true
        },
        {
            "command": "npm run test:filter",
            "name": "Debug npm test:filter (terminal)",
            "request": "launch",
            "type": "node-terminal"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Run playwright",
            "runtimeExecutable": "playwright",
            "cwd": "${workspaceFolder}",
            "args": []
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch Chrome against localhost",
            "url": "http://localhost:5173",
            "webRoot": "${workspaceFolder}"
        }
    ]
}